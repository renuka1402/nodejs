<%- include("header") %>

<div class="main-content">
    <div class="form-card">
        <div class="form-intro">
            <h2>Edit Blog Post</h2>
            <p>Update the information below to revise your post.</p>
        </div>

        <form action="/edit/<%= post._id %>" method="POST" enctype="multipart/form-data" class="modern-form">
            
            <div class="input-group">
                <label for="title">Post Title</label>
                <input type="text" id="title" name="title" value="<%= post.title %>" required>
            </div>

            <div class="input-group">
                <label for="category">Category</label>
                <input type="text" id="category" name="category" value="<%= post.category %>" required>
            </div>

            

         

            <div class="input-group">
                <label for="content">Post Content</label>
                <textarea id="content" name="content" rows="10" required><%= post.content %></textarea>
            </div>

            <div class="form-footer">
                <button type="submit" class="submit-btn">Update Post</button>
                <a href="/" class="cancel-link">Cancel</a>
            </div>

        </form>
    </div>
</div>