<%- include('partials/header') %>
<section style="margin-bottom: 30px;">
    <h2>Add Category</h2>

    <% if (error) { %>
        <p style="color: red;"><%= error %></p>
    <% } %>

    <form method="POST" action="/categories" >
        <label for="name">Category Name</label>
        <input type="text" id="name" name="name" placeholder="Food, Travel, Salary" required style="display:block; width:100%; padding:10px; margin:10px 0;">
        <button type="submit" style="padding:10px 16px;">Create Category</button>
    </form>
</section>

<section>
    <h2>All Categories</h2>

    <% if (categories && categories.length > 0) { %>
        <table style="width: 100%; ">
            <thead>
                <tr>
                    <th >Category Name</th>
                </tr>
            </thead>
            <tbody>
                <% categories.forEach((category) => { %>
                    <tr>
                        <td ><%= category.name %></td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    <% } else { %>
        <p>No categories found.</p>
    <% } %>
</section>
<%- include('partials/footer') %>
