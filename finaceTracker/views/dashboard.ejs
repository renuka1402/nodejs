<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    
<h3>My Finance Dashboard</h3>
  <nav class="simple-nav" aria-label="Primary">
                <a href="/dashboard">Home</a>
                <a href="/transaction/add">Add Transaction</a>
                <a href="/categories">Categories</a>
                <a href="/budgets">Budget</a>
                <a href="/logout">Logout</a>
            </nav>
<p>
    <b>Total Balance:</b> <%= balance %> | 
    <span style="color: green;"><b>Income:</b> <%= totalIncome %></span> | 
    <span style="color: red;"><b>Expense:</b> <%= totalExpense %></span>
</p>

<hr>



<table width="100%">
    <tr>
        <td width="50%" valign="top">
            <h4>Expense Breakdown</h4>
            <div style="width: 200px;">
                <canvas id="expenseChart"></canvas>
            </div>
        </td>
        
    </tr>
</table>

<hr>

<h4>Recent Transactions</h4>
<table border="1"  width="100%" >
    <thead>
        <tr style="background: #eee;">
            <th>Date</th>
            <th>Category</th>
            <th>Type</th>
            <th>Amount</th>
        </tr>
    </thead>
    <tbody>
        <% if (transactions.length > 0) { %>
            <% transactions.forEach(t => { %>
                <tr>
                    <td><%= new Date(t.date).toLocaleDateString() %></td>
                    <td><%= t.category.name %></td>
                    <td><%= t.type %></td>
                    <td ><b><%= t.amount %></b></td>
                </tr>
            <% }) %>
        <% } else { %>
            <tr><td >No data found.</td></tr>
        <% } %>
    </tbody>
</table>



<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const ctx = document.getElementById('expenseChart').getContext('2d');
    new Chart(ctx, {
        type: 'pie',
        data: {
            labels: <%- JSON.stringify(chartLabels) %>,
            datasets: [{
                data: <%- JSON.stringify(chartValues) %>,
                backgroundColor: ['red', 'blue', 'yellow', 'green', 'purple', 'orange']
            }]
        }
    });
</script>
</body>
</html>
